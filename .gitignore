# 1. Ignorar todo
*
!*/
# 2. No ignorar el propio .gitignore
!.gitignore

# 3. PERMITIR carpetas raíz (esto es necesario para que Git pueda entrar)
!.config/
!.zshrc
!Documentos/
!Pictures/
!Scripts/
!Descargas/

# 4. LISTA BLANCA (Lo que SÍ quieres guardar)

# Apps en .config
!.config/nvim/**
!.config/dunst/**
!.config/rofi/**
!.config/picom/**
!.config/Thunar/**
!.config/kitty/**
!.config/fastfetch/**
!.config/foot/**
!.config/hypr/**
!.config/uwsm/**
!.config/i3/**
!.config/polybar/**
!.config/systemd/**
!.config/matplotlib/**
!.config/starship.toml
!.config/brave-flags.conf

# Contenido específico en subcarpetas
!Documentos/Backup/**

# Ignore
.bun/
.cache/
.cargo/
.donet/
.gnupg/
.java/
.local/
.m2/
.mozilla/
.pki/
.vscode/
.zen/
